{
  "models": [
    {
      "title": "DeepSeek Coder — Ollama",
      "provider": "ollama",
      "model": "deepseek-coder",
      "apiBase": "http://ollama:11434",
      "contextLength": 16384,
      "maxTokens": 4096,
      "temperature": 0.2
    },
    {
      "title": "CodeLlama — Ollama",
      "provider": "ollama",
      "model": "codellama",
      "apiBase": "http://ollama:11434",
      "contextLength": 16384,
      "maxTokens": 4096,
      "temperature": 0.3
    },
    {
      "title": "Llama 3 — General",
      "provider": "ollama",
      "model": "llama3",
      "apiBase": "http://ollama:11434",
      "contextLength": 8192,
      "maxTokens": 4096,
      "temperature": 0.7
    },
    {
      "title": "Mistral — Fast",
      "provider": "ollama",
      "model": "mistral",
      "apiBase": "http://ollama:11434",
      "contextLength": 8192,
      "maxTokens": 4096,
      "temperature": 0.5
    }
  ],

  "tabAutocompleteModel": {
    "title": "Tab Autocomplete — DeepSeek",
    "provider": "ollama",
    "model": "deepseek-coder:1.3b",
    "apiBase": "http://ollama:11434",
    "contextLength": 2048,
    "maxTokens": 256,
    "temperature": 0.01
  },

  "embeddingsProvider": {
    "provider": "ollama",
    "model": "nomic-embed-text",
    "apiBase": "http://ollama:11434"
  },

  "contextProviders": [
    { "name": "file",     "params": {} },
    { "name": "folder",   "params": {} },
    { "name": "codebase", "params": {} },
    { "name": "docs",     "params": {} },
    { "name": "tree",     "params": {} },
    { "name": "grep",     "params": {} },
    { "name": "url",      "params": {} },
    { "name": "github",   "params": {} }
  ],

  "slashCommands": [
    { "name": "edit",    "description": "Edit code in place" },
    { "name": "comment", "description": "Write comments for selected code" },
    { "name": "test",    "description": "Generate unit tests" },
    { "name": "explain", "description": "Explain selected code" },
    { "name": "review",  "description": "Review selected code for bugs & style" }
  ],

  "customCommands": [
    {
      "name": "review",
      "prompt": "{{{input}}}\n\nReview the above code. Check for:\n1. Bugs or logical errors\n2. Security vulnerabilities\n3. Performance issues\n4. Code style improvements\n\nBe concise and specific.",
      "description": "Review selected code"
    },
    {
      "name": "docstring",
      "prompt": "{{{input}}}\n\nWrite a complete docstring for the above function. Include: summary, parameters, return type, and a usage example.",
      "description": "Generate docstring"
    }
  ],

  "allowAnonymousTelemetry": false,

  "ui": {
    "codeBlockTheme": "github-dark",
    "fontSize": 14,
    "fontFamily": "JetBrains Mono, Fira Code, monospace"
  }
}
