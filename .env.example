# Atomia Cloud Suite - Environment Variables
# Copy this file to .env and customize

# ============================================
# STORAGE PATHS
# ============================================
OLLAMA_DATA_PATH=./data/ollama
OPENWEBUI_DATA_PATH=./data/openwebui
CODER_DATA_PATH=./data/code-server
CODER_SSH_PATH=./data/code-server-ssh
PROJECTS_PATH=./projects
GITEA_DATA_PATH=./data/gitea
GITEA_SSH_PATH=./data/gitea-ssh
GITEA_RUNNER_PATH=./data/gitea-runner
QDRANT_DATA_PATH=./data/qdrant
PROMETHEUS_DATA_PATH=./data/prometheus
GRAFANA_DATA_PATH=./data/grafana

# ============================================
# SECURITY - CHANGE THESE PASSWORDS
# ============================================
CODER_PASSWORD=change_this_password
WEBUI_SECRET_KEY=change_this_secure_key_in_production
WEBUI_AUTH_SECRET=

# Custom VS Code Extensions (URLs separated by comma)
# Example: EXTENSION_URLS=https://github.com/username/extension/releases/download/v1.0.0/extension-1.0.0.vsix
EXTENSION_URLS=

# Nginx Proxy Manager
NGINX_ADMIN_USER=admin
NGINX_ADMIN_PASSWORD=change_nginx_password

# Grafana
GRAFANA_PASSWORD=admin

# ============================================
# RAG CONFIGURATION (Vector Database)
# ============================================
QDRANT_API_KEY=

# ============================================
# GITEA AUTHENTICATION
# ============================================
GITEA_DOMAIN=localhost
GITEA_ROOT_URL=http://localhost:3000/
GITEA_DISABLE_REGISTRATION=false
GITEA_REQUIRE_SIGNIN=false
GITEA_ALLOW_EXTERNAL_AUTH=false
GITEA_ENABLE_CAPTCHA=false
GITEA_KEEP_EMAIL_PRIVATE=false

# Gitea Runner Token (generate after first run)
GITEA_RUNNER_TOKEN=

# ============================================
# EMAIL NOTIFICATIONS (SMTP)
# ============================================
# Enable email notifications
MAIL_ENABLED=false

# SMTP Server Configuration
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=notifications@atomia.local
MAIL_PASSWORD=your_smtp_password
MAIL_FROM=Atomia Gitea <noreply@atomia.local>
MAIL_SKIP_VERIFY=true

# ============================================
# GPU CONFIGURATION
# ============================================
NVIDIA_VISIBLE_DEVICES=all

# ============================================
# DOMAIN CONFIGURATION
# ============================================
DOMAIN=atomia.local