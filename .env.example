# =============================================================================
# Atomia Cloud Suite — Environment Variables v4.0
# Copy this file to .env and customize before running setup.sh
# =============================================================================

# ============================================
# STORAGE PATHS
# ============================================
OLLAMA_DATA_PATH=./data/ollama
OPENWEBUI_DATA_PATH=./data/openwebui
CODER_DATA_PATH=./data/code-server
CODER_SSH_PATH=./data/code-server-ssh
PROJECTS_PATH=./projects
AUTHELIA_DATA_PATH=./data/authelia
GITEA_DATA_PATH=./data/gitea
GITEA_SSH_PATH=./data/gitea-ssh
GITEA_RUNNER_PATH=./data/gitea-runner
QDRANT_DATA_PATH=./data/qdrant
PROMETHEUS_DATA_PATH=./data/prometheus
GRAFANA_DATA_PATH=./data/grafana

# ============================================
# SECURITY — CHANGE ALL OF THESE
# ============================================
# Code Server web password
CODER_PASSWORD=change_this_password

# Open WebUI session secret (min 32 chars)
WEBUI_SECRET_KEY=change_this_secure_key_32chars_min
WEBUI_AUTH_SECRET=

# Default role for new Open WebUI users (user | admin)
OPENWEBUI_DEFAULT_ROLE=user

# ============================================
# AUTHELIA — SSO & MFA
# Generate each secret: openssl rand -hex 32
# ============================================
AUTHELIA_JWT_SECRET=change_this_jwt_secret_min32chars_xxxxx
AUTHELIA_SESSION_SECRET=change_this_session_secret_32chars_x
AUTHELIA_STORAGE_KEY=change_this_storage_key_32chars_xxxx

# ============================================
# QDRANT Vector Store
# ============================================
# Optional API key to protect the Qdrant REST API
QDRANT_API_KEY=

# RAG embedding model (leave default for local Ollama)
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ============================================
# OLLAMA — GPU & Resource Config
# ============================================
# GPU IDs to expose: all | 0 | 0,1 | none (CPU-only)
NVIDIA_VISIBLE_DEVICES=all

# Max concurrently loaded models (reduce on low VRAM)
OLLAMA_MAX_LOADED_MODELS=2

# Resource limits for Ollama container
OLLAMA_MEM_LIMIT=16G
OLLAMA_CPU_LIMIT=4.0

# ============================================
# GITEA — Authentication & Email
# ============================================
GITEA_DOMAIN=localhost
GITEA_ROOT_URL=http://localhost:3000/
GITEA_DISABLE_REGISTRATION=false
GITEA_REQUIRE_SIGNIN=false
GITEA_ENABLE_CAPTCHA=false
GITEA_RUNNER_TOKEN=

# Email / SMTP
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=notifications@atomia.local
MAIL_PASSWORD=your_smtp_password
MAIL_FROM=Atomia Gitea <noreply@atomia.local>
MAIL_SKIP_VERIFY=true

# ============================================
# MONITORING
# ============================================
GRAFANA_PASSWORD=admin

# ============================================
# VS CODE EXTENSIONS (comma-separated .vsix URLs)
# ============================================
# EXTENSION_URLS=https://github.com/owner/repo/releases/download/v1.0/ext.vsix

EXTENSION_URLS=

# ============================================
# BACKUP
# ============================================
# Optional AES-256 encryption passphrase
BACKUP_PASSPHRASE=

# Optional rclone remote (e.g. s3:my-bucket or gdrive:backups)
RCLONE_REMOTE=

# Days to keep local backups
RETENTION_DAYS=7

# ============================================
# DOMAIN (for production Nginx Proxy setup)
# ============================================
DOMAIN=atomia.local
