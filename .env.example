# Atomia Cloud Suite - Environment Variables
# Copy this file to .env and customize

# ============================================
# STORAGE PATHS (where data is persisted)
# ============================================
# Path to store Ollama AI models (10-50GB+ recommended)
OLLAMA_DATA_PATH=./data/ollama

# Path to store Open WebUI data (chats, uploads)
OPENWEBUI_DATA_PATH=./data/openwebui

# Path to store Code Server config and extensions
CODER_DATA_PATH=./data/code-server

# Path to store your projects (git repos, source code)
PROJECTS_PATH=./projects

# Path to store Gitea data (git repos, database)
GITEA_DATA_PATH=./data/gitea

# Path to store Gitea SSH keys
GITEA_SSH_PATH=./data/gitea-ssh

# ============================================
# SECURITY - CHANGE THESE PASSWORDS
# ============================================
# Code Server password
CODER_PASSWORD=change_this_password

# Open WebUI secret key
WEBUI_SECRET_KEY=change_this_secure_key_in_production

# Gitea admin credentials
GITEA_ADMIN_USER=admin
GITEA_ADMIN_PASSWORD=change_gitea_password
GITEA_ADMIN_EMAIL=admin@atomia.local

# Nginx Proxy Manager credentials
NGINX_ADMIN_USER=admin
NGINX_ADMIN_PASSWORD=change_nginx_password

# ============================================
# GPU CONFIGURATION
# ============================================
# Set to 'all' to use all GPUs, or specific GPU IDs (e.g., '0,1')
NVIDIA_VISIBLE_DEVICES=all

# ============================================
# DOMAIN CONFIGURATION (for external access)
# ============================================
# Your domain name (if using Nginx Proxy Manager with SSL)
DOMAIN=atomia.local

# ============================================
# GITEA CONFIGURATION
# ============================================
# SSH clone URL format (use IP or domain)
GITEA_SSH_DOMAIN=localhost
GITEA_HTTP_DOMAIN=localhost
